# =========================================================================
# Modèle d'environnement BACKEND pour le déploiement Railway.
# -------------------------------------------------------------------------
# Ce fichier N'EST PAS lu par Railway directement (il sert de référence pour
# `railway variables set`). Le bloc `${{Postgres.DATABASE_URL}}` est une
# REFERENCE de variable Railway : elle est résolue au moment du build/deploy.
# -------------------------------------------------------------------------
# Procédure d'injection (voir aussi deploy.sh + README) :
#
#   railway variables set DATABASE_URL='${{Postgres.DATABASE_URL}}'
#   railway variables set REDIS_URL='${{Redis.REDIS_URL}}'
#   railway variables set OSRM_BASE_URL='https://<votre-osrm-public>'
#   railway variables set GOOGLE_ROUTES_API_KEY='AIza...'
#   railway variables set API_SECRET_KEY='<chaine_aleatoire_32+_car>'
#   railway variables set ALLOWED_ORIGINS='https://<votre-frontend>.app'
#   railway variables set TZ=Africa/Abidjan
#   railway variables set COLLECT_INTERVAL_MINUTES=15
#   railway variables set COLLECT_START_HOUR=7
#   railway variables set COLLECT_END_HOUR=19
#   railway variables set REFERENCE_SPEED_KMH=50
#   railway variables set TTI_SEUIL_DENSE=1.3
#   railway variables set TTI_SEUIL_CONGESTIONNE=2.0
#
# ⚠️  Plafond Google : 250 req/jour. Avec 6 tronçons :
#       15 min × 12h = 288 req/jour → DÉPASSE le plafond.
#       20 min × 12h = 216 req/jour → OK (recommandé en prod).
#     COLLECT_INTERVAL_MINUTES=15 est gardé ici par fidélité au brief, mais
#     monitorer les logs du backend : un WARNING au démarrage signale le
#     dépassement. Passer à 20 dès que possible si pas de bypass quota.
# =========================================================================

# --- Base de données (auto-injectée par le plugin Postgres) ---
# Le normaliseur dans app/db/session.py convertit automatiquement
# `postgresql://...` en `postgresql+psycopg://...` (driver psycopg v3).
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Cache Redis (auto-injecté par le plugin Redis) ---
REDIS_URL=${{Redis.REDIS_URL}}

# --- Moteur de routage interne OSRM ---
# Railway ne peut pas héberger OSRM (extrait OSM trop volumineux).
# Voir CLAUDE.md § Déploiement pour les deux options :
#   - Option A : OSRM local exposé via ngrok (test : https://xxxx.ngrok-free.app)
#   - Option B : OSRM sur Oracle Cloud Free Tier (permanent : https://osrm.example.com)
OSRM_BASE_URL=https://REMPLACER-PAR-VOTRE-URL-OSRM-PUBLIQUE

# --- Clé Google Routes (TRAFFIC_AWARE_OPTIMAL) ---
GOOGLE_ROUTES_API_KEY=REMPLACER_PAR_VOTRE_CLE_GOOGLE

# --- Sécurité API ---
API_SECRET_KEY=REMPLACER_PAR_CHAINE_ALEATOIRE_32_CARACTERES_MINIMUM
ALLOWED_ORIGINS=https://REMPLACER-PAR-VOTRE-FRONTEND.up.railway.app,https://REMPLACER-PAR-VOTRE-DOMAINE.com

# --- Fuseau horaire métier ---
TZ=Africa/Abidjan

# --- Paramètres de collecte (P2) ---
COLLECT_INTERVAL_MINUTES=15
COLLECT_START_HOUR=7
COLLECT_END_HOUR=19
REFERENCE_SPEED_KMH=50

# --- Seuils d'analyse FHWA (P3) — surchargent les valeurs par défaut ---
TTI_SEUIL_DENSE=1.3
TTI_SEUIL_CONGESTIONNE=2.0
TTI_SEUIL_HEURE_POINTE=1.5
