# ============================================================
# Modèle d'environnement BACKEND — PAA-Traverse
# ------------------------------------------------------------
# Copier ce fichier en `.env` et compléter les valeurs.
# NE JAMAIS commiter le fichier `.env` (cf. .gitignore racine).
# ============================================================

# === Base de données PostgreSQL ===
POSTGRES_USER=paa
POSTGRES_PASSWORD=<un_mot_de_passe_fort>
POSTGRES_DB=paa_traffic
# URL utilisée par SQLAlchemy (driver psycopg v3)
DATABASE_URL=postgresql+psycopg://paa:<le_meme_mot_de_passe>@db:5432/paa_traffic

# === Clés des services externes ===
# Google Routes API (source primaire unique en temps réel, mode TRAFFIC_AWARE_OPTIMAL).
# TomTom a été retiré du projet (aucune couverture à Abidjan — cf. CLAUDE.md § 2.5).
GOOGLE_ROUTES_API_KEY=<votre_cle_google_AIza...>

# === Moteur de routage interne OSRM (auto-hébergé) ===
OSRM_BASE_URL=http://osrm:5000

# === Cache Redis ===
REDIS_URL=redis://redis:6379/0

# === Paramètres de collecte (APScheduler) ===
# Intervalle entre deux collectes, en minutes
COLLECT_INTERVAL_MINUTES=15
# Plage horaire active (heures locales, fuseau TZ ci-dessous)
COLLECT_START_HOUR=7
COLLECT_END_HOUR=19
# Vitesse de référence utilisée pour le temps théorique à fluide
REFERENCE_SPEED_KMH=50
# Fuseau horaire de référence du PAA
TZ=Africa/Abidjan

# === Sécurité de l'API ===
# Clé utilisée pour signer les jetons internes (≥ 32 caractères aléatoires)
API_SECRET_KEY=<une_longue_chaine_aleatoire>
# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000
