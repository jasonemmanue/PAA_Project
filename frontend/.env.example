# ============================================================
# Modèle d'environnement FRONTEND — PAA-Traverse
# ------------------------------------------------------------
# Copier ce fichier en `.env.local` et compléter les valeurs.
# Les variables exposées au navigateur DOIVENT être préfixées
# par `NEXT_PUBLIC_` (convention Next.js).
# NE JAMAIS commiter le fichier `.env.local` (cf. .gitignore racine).
# ============================================================

# === URL de l'API backend FastAPI ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

# === Langue par défaut de l'interface (fr | en) ===
NEXT_PUBLIC_DEFAULT_LANG=fr

# === Fournisseur de tuiles cartographiques ===
# URL de modèle de tuiles OpenStreetMap (peut être remplacée par un miroir privé)
NEXT_PUBLIC_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_TILE_ATTRIBUTION=&copy; OpenStreetMap contributors

# === Chatbot Gemini ===
# Clé API Google Gemini pour le chatbot d'aide intégré.
# Obtenir une clé GRATUITE (sans carte bancaire) en 2 minutes :
#   1. Aller sur https://aistudio.google.com/app/apikey
#   2. Cliquer "Create API key" → copier la clé générée (format AIza...)
#   3. Coller la clé ci-dessous
# Si cette variable est absente ou vide, le chatbot demandera la clé
# directement dans l'interface (mode temporaire — non persisté).
NEXT_PUBLIC_GEMINI_API_KEY=
